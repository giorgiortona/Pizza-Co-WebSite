        {t("storia.awards.subtitle")}
      </p>
      <h2
        class="text-4xl sm:text-5xl font-serif text-brand-dark leading-tight mb-6 js-award-reveal opacity-0"
      >
        {t("storia.awards.title")}
      </h2>
      <div
        class="w-16 h-1 bg-brand-gold rounded-full mx-auto mb-12 js-award-reveal opacity-0"
      >
      </div>

      <p
        class="text-lg text-brand-dark/80 leading-relaxed max-w-2xl mx-auto mb-16 js-award-reveal opacity-0"
      >
        {t("storia.awards.desc")}
      </p>

      <div
        class="flex flex-wrap justify-center gap-4 sm:gap-6 lg:gap-8 max-w-6xl mx-auto js-award-reveal opacity-0"
