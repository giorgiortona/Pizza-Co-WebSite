---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../data/site";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const tPath = useTranslatedPath(lang);
---

<BaseLayout title={t("storia.hero.title")}>
  <!-- Hero Section -->
  <header
    class="relative bg-[#12100e] text-white pt-40 pb-32 md:pt-48 md:pb-40 overflow-hidden -mt-24 md:-mt-32"
  >
    <div class="absolute inset-0 z-0">
      <img
        src="/images/hero/foto-2.jpg"
        alt={t("storia.hero.title")}
        class="w-full h-full object-cover opacity-70 js-storia-parallax scale-110 object-[50%_40%]"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-[#12100e]/80 via-[#12100e]/20 to-transparent"
      >
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
      <p
        class="text-sm font-bold uppercase tracking-[0.3em] text-brand-gold mb-6 js-storia-reveal opacity-0"
      >
        {t("storia.hero.subtitle")}
      </p>
      <h1
        class="text-5xl sm:text-7xl md:text-8xl font-serif tracking-tight mb-8 js-storia-reveal opacity-0"
      >
        {t("storia.hero.title")}
      </h1>
      <p
        class="text-xl sm:text-2xl text-white/90 max-w-2xl mx-auto leading-relaxed font-light js-storia-reveal opacity-0"
      >
        {t("storia.hero.desc")}
      </p>
    </div>
  </header>

  <div class="bg-brand-cream py-24 sm:py-32 relative overflow-hidden">
    <!-- Background Elements -->
    <div
      class="absolute top-0 right-0 w-[800px] h-[800px] bg-brand-gold/5 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/3"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-brand-red/5 rounded-full blur-[80px] translate-y-1/3 -translate-x-1/3"
    >
    </div>

    <div class="mx-auto max-w-5xl px-6 relative z-10 space-y-32">
      <!-- Section 1: Chi siamo -->
      <section
        class="grid md:grid-cols-2 gap-12 items-center js-storia-section"
      >
        <div
          class="order-2 md:order-1 relative rounded-3xl overflow-hidden aspect-[3/2] shadow-2xl"
        >
          <img
            src="/images/hero/Mauri.jpg"
            alt={t("storia.s1.title")}
            class="w-full h-full object-cover js-storia-img scale-105"
          />
          <div
            class="absolute inset-0 ring-1 ring-inset ring-black/10 rounded-3xl"
          >
          </div>
        </div>
        <div class="order-1 md:order-2 space-y-6 md:pl-10 js-storia-text">
          <h2
            class="text-4xl sm:text-5xl font-serif text-brand-dark leading-tight"
          >
            {t("storia.s1.title")}
          </h2>
          <div class="w-16 h-1 bg-brand-red rounded-full"></div>
          <p class="text-lg text-brand-dark/80 leading-relaxed pt-4">
            <strong class="text-brand-dark font-medium">{site.name}</strong>
            {t("storia.s1.p1")}
          </p>
          <p class="text-lg text-brand-dark/80 leading-relaxed mt-4">
            {t("storia.s1.p2")}
          </p>
        </div>
      </section>

      <!-- Section 2: La nostra filosofia -->
      <section
        class="grid md:grid-cols-2 gap-12 items-center js-storia-section"
      >
        <div class="space-y-6 md:pr-10 js-storia-text">
          <h2
            class="text-4xl sm:text-5xl font-serif text-brand-dark leading-tight"
          >
            {t("storia.s2.title1")}
            <br /><span class="text-brand-gold italic"
              >{t("storia.s2.title2")}</span
            >
          </h2>
          <div class="w-16 h-1 bg-brand-gold rounded-full mb-6 mt-6"></div>
          <div
            class="text-lg text-brand-dark/90 leading-relaxed whitespace-pre-line italic border-l-4 border-brand-gold/50 pl-6 py-4 bg-brand-gold/5 rounded-r-2xl shadow-sm"
          >
            {t("storia.s2.p1")}
          </div>
          <p
            class="text-md sm:text-lg text-brand-dark/80 leading-relaxed mt-6 font-medium text-right"
          >
            {t("storia.s2.p2")}
          </p>
        </div>
        <div
          class="relative rounded-3xl overflow-hidden aspect-[5/4] shadow-2xl"
        >
          <img
            src="/images/hero/MammaePapa.png"
            alt={t("storia.s2.title2")}
            class="w-full h-full object-cover js-storia-img scale-105"
          />
          <div class="absolute inset-0 bg-black/10">
          </div>
          <div
            class="absolute inset-0 ring-1 ring-inset ring-black/10 rounded-3xl"
          >
          </div>
        </div>
      </section>
    </div>
  </div>

  <!-- Awards Section -->
  <section class="bg-brand-cream pb-24 sm:pb-32 relative overflow-hidden">
    <div
      class="mx-auto max-w-5xl px-6 relative z-10 text-center js-awards-section"
    >
      <p
        class="text-sm font-bold uppercase tracking-[0.3em] text-brand-gold mb-4 js-award-reveal opacity-0"
