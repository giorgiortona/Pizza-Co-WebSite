<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;

  if (!prefersReducedMotion) {
    // Hero Entrance
    gsap.fromTo(
      ".js-storia-reveal",
      { y: 30, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 1,
        stagger: 0.15,
        ease: "power3.out",
        delay: 0.1,
      }
    );

    // Hero Parallax effect gently
    gsap.to(".js-storia-parallax", {
      scrollTrigger: {
        trigger: "header",
        start: "top top",
        end: "bottom top",
        scrub: true,
      },
      yPercent: 15,
      ease: "none",
    });

    // Content Sections Scroll Animation
    const sections = gsap.utils.toArray<HTMLElement>(".js-storia-section");

    sections.forEach((section) => {
      const text = section.querySelector(".js-storia-text");
      const img = section.querySelector(".js-storia-img");

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          once: true,
        },
      });

      tl.fromTo(
        text,
        { y: 40, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.8, ease: "power3.out" }
      );

      if (img) {
        tl.fromTo(
          img,
          { scale: 1.15, filter: "blur(10px)", opacity: 0 },
          {
            scale: 1.05,
            filter: "blur(0px)",
            opacity: 1,
            duration: 1.2,
            ease: "power2.out",
          },
          "-=0.6"
        );
      }
    });

    // Call to Action Parallax and Reveal
    gsap.to(".js-cta-parallax", {
      scrollTrigger: {
        trigger: ".js-storia-cta",
        start: "top bottom",
        end: "bottom top",
        scrub: true,
      },
      yPercent: 20,
      ease: "none",
    });

    gsap.fromTo(
      ".js-cta-reveal",
      { y: 30, opacity: 0 },
      {
        scrollTrigger: {
          trigger: ".js-storia-cta",
          start: "top 75%",
          once: true,
        },
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.15,
        ease: "power3.out",
      }
    );

    // Awards Section Reveal
    gsap.fromTo(
      ".js-award-reveal",
      { y: 30, opacity: 0 },
      {
        scrollTrigger: {
          trigger: ".js-awards-section",
          start: "top 75%",
          once: true,
        },
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.15,
        ease: "power3.out",
      }
    );
  } else {
    document
      .querySelectorAll(".js-storia-reveal, .js-cta-reveal, .js-award-reveal")
      .forEach((el) => {
        el.classList.remove("opacity-0");
      });
  }
</script>
