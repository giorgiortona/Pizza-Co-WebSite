---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../data/site";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('contatti.hero.title')}>
  <!-- Hero Section -->
  <header class="relative bg-[#12100e] text-white pt-40 pb-32 md:pt-48 md:pb-40 overflow-hidden -mt-24 md:-mt-32">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-[url('/images/hero/foto-4.jpg')] bg-cover bg-center opacity-60"></div>
      <div class="absolute inset-0 bg-gradient-to-br from-[#12100e]/90 via-[#12100e]/50 to-brand-red/10"></div>
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-gold/10 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/3"></div>
    </div>
    
    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
      <p class="text-sm font-bold uppercase tracking-[0.3em] text-brand-gold mb-6 js-contatti-reveal opacity-0">
        {t('contatti.hero.subtitle')}
      </p>
      <h1 class="text-5xl sm:text-7xl md:text-8xl font-serif tracking-tight mb-8 js-contatti-reveal opacity-0">
        {t('contatti.hero.title')}
      </h1>
      <p class="text-xl sm:text-2xl text-white/80 max-w-2xl mx-auto leading-relaxed font-light js-contatti-reveal opacity-0">
        {t('contatti.hero.desc')}
      </p>
    </div>
  </header>

  <div class="bg-brand-cream py-24 relative overflow-hidden">
    <div class="mx-auto max-w-6xl px-6 space-y-12">
      <div class="grid gap-8 md:grid-cols-2">
        <!-- Contatti Card -->
        <section class="js-contatti-card opacity-0 rounded-3xl border border-brand-dark/10 bg-brand-card p-8 sm:p-12 shadow-xl relative overflow-hidden transition-transform duration-300 hover:-translate-y-1 hover:shadow-2xl">
          <div class="flex items-start gap-6 relative z-10">
            <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-brand-cream text-brand-red border border-brand-red/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92V19a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 3 5.18 2 2 0 0 1 5 3h2.09a2 2 0 0 1 2 1.72c.12.86.37 1.7.72 2.49a2 2 0 0 1-.45 2.11L8.09 10.91a16 16 0 0 0 5 5l1.59-1.27a2 2 0 0 1 2.11-.45c.79.35 1.63.6 2.49.72A2 2 0 0 1 22 16.92z" />
              </svg>
            </div>
            <div class="min-w-0">
              <h2 class="text-3xl font-serif text-brand-dark mb-4">{t('contatti.call.title')}</h2>
              <p class="text-brand-dark/70 mb-6 font-light leading-relaxed">
                {t('contatti.call.desc')}
              </p>
              <div class="space-y-3">
                <div class="flex flex-col gap-1">
                  <a href={`tel:${site.phone}`} class="block text-xl font-medium text-brand-dark transition-colors hover:text-brand-red">
                    {site.phone}
                  </a>
                  <span class="text-xs font-semibold text-brand-red uppercase tracking-wide">{t('contact.no_reservations')}</span>
                </div>
                <a href={`mailto:${site.email}`} class="block text-lg font-medium text-brand-dark/80 transition-colors hover:text-brand-red">
                  {site.email}
                </a>
              </div>
            </div>
          </div>
        </section>

        <!-- Metodi di Pagamento Card -->
        <section class="js-contatti-card opacity-0 rounded-3xl border border-brand-dark/10 bg-brand-card p-8 sm:p-12 shadow-xl relative overflow-hidden transition-transform duration-300 hover:-translate-y-1 hover:shadow-2xl flex flex-col">
          <div class="flex flex-col h-full relative z-10 w-full">
            <div class="flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left gap-6 mb-6 w-full">
              <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-[#ffebed] text-[#e6324b] border border-[#e6324b]/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="6" width="18" height="12" rx="2" />
                  <path d="M7 10h10" />
                  <path d="M7 14h4" />
                </svg>
              </div>
              <div class="min-w-0 flex-1 overflow-hidden relative flex flex-col items-center sm:items-start w-full">
                <h2 class="text-3xl font-serif text-brand-dark mb-4 relative z-10">{t('contatti.pay.title')}</h2>
                
                <div class="relative w-full max-w-[200px] sm:max-w-none overflow-hidden h-10 flex items-center group mask-edges">
                  <div class="absolute inset-y-0 left-0 w-6 bg-gradient-to-r from-white to-transparent z-10"></div>
                  <div class="absolute inset-y-0 right-0 w-6 bg-gradient-to-l from-white to-transparent z-10"></div>
                  
                  <div class="flex whitespace-nowrap animate-[marquee_12s_linear_infinite] items-center gap-6 group-hover:[animation-play-state:paused]">
                    <!-- Logos group 1 -->
                    <div class="flex items-center gap-6 shrink-0">
                      <img src="/icons/Satispay.svg" alt="Satispay" class="h-7 w-auto mix-blend-multiply" />
                      <span class="font-bold text-2xl text-[#1434cb] italic tracking-tighter mix-blend-multiply">VISA</span>
                      <div class="flex items-center"><div class="w-6 h-6 rounded-full bg-[#eb001b]/90 mix-blend-multiply"></div><div class="w-6 h-6 rounded-full bg-[#f79e1b]/90 mix-blend-multiply -ml-2.5"></div></div>
                      <div class="bg-[#006fcf] text-white font-bold text-[10px] px-2 py-1 rounded-sm tracking-widest h-6 flex items-center">AMEX</div>
                    </div>
                    <!-- Logos group 2 -->
                    <div class="flex items-center gap-6 shrink-0">
                      <img src="/icons/Satispay.svg" alt="Satispay" class="h-7 w-auto mix-blend-multiply" />
                      <span class="font-bold text-2xl text-[#1434cb] italic tracking-tighter mix-blend-multiply">VISA</span>
                      <div class="flex items-center"><div class="w-6 h-6 rounded-full bg-[#eb001b]/90 mix-blend-multiply"></div><div class="w-6 h-6 rounded-full bg-[#f79e1b]/90 mix-blend-multiply -ml-2.5"></div></div>
                      <div class="bg-[#006fcf] text-white font-bold text-[10px] px-2 py-1 rounded-sm tracking-widest h-6 flex items-center">AMEX</div>
                    </div>
                  </div>
                </div>

              </div>
            </div>
            
            <p class="text-brand-dark/70 font-light leading-relaxed mb-6 flex-1 text-center sm:text-left">
              {t('contatti.pay.desc')}
            </p>

            <div class="flex justify-center bg-brand-cream/50 rounded-2xl p-6 border border-brand-dark/5 mt-auto">
              <button class="js-qr-trigger focus:outline-none focus:ring-2 focus:ring-brand-red rounded-xl transition-transform duration-300 hover:scale-105" aria-label="Ingrandisci QR code Satispay">
                <img src="/images/satispay_qr.jpg" alt="QR code Satispay" class="w-32 h-32 rounded-xl shadow-sm mix-blend-multiply pointer-events-none" />
              </button>
            </div>
          </div>
        </section>
      </div>

      <!-- Social Media Section -->
      <section class="js-contatti-card opacity-0 rounded-3xl border border-brand-dark/10 bg-brand-card p-8 sm:p-12 shadow-xl flex flex-col sm:flex-row items-center justify-between gap-8">
        <div>
          <h2 class="text-3xl font-serif text-brand-dark mb-2 text-center sm:text-left">{t('contatti.social.title')}</h2>
          <p class="text-brand-dark/70 text-center sm:text-left">{t('contatti.social.desc')}</p>
        </div>

        <div class="flex items-center gap-4">
          {[
            { url: site.instagramUrl, icon: "instagram.svg", alt: "Instagram" },
            { url: site.facebookUrl, icon: "facebook.svg", alt: "Facebook" },
            { url: `https://wa.me/${site.phone}`, icon: "whatsapp.svg", alt: "WhatsApp" },
            { url: site.tiktokUrl, icon: "tiktok.svg", alt: "TikTok" }
          ].map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noreferrer"
              class="flex h-14 w-14 items-center justify-center rounded-full border border-brand-dark/10 bg-brand-cream transition-all duration-300 hover:-translate-y-1 hover:border-brand-red/30 hover:bg-brand-card hover:shadow-lg group"
            >
              <img src={`/icons/${social.icon}`} alt={social.alt} class="h-6 w-6 object-contain group-hover:scale-110 transition-transform duration-300 theme-invert-in-dark" />
            </a>
          ))}
        </div>
      </section>
    </div>
  </div>

  <!-- QR Code Modal (Hidden by default) -->
  <div id="qr-modal" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/80 backdrop-blur-sm opacity-0 invisible transition-all duration-300">
    <div class="relative max-w-[90vw] max-h-[90vh] bg-brand-card rounded-3xl p-4 sm:p-8 shadow-2xl scale-95 transition-transform duration-300" id="qr-modal-content">
      <button id="close-qr-modal" class="absolute -top-4 -right-4 flex h-10 w-10 items-center justify-center rounded-full bg-brand-card text-brand-dark shadow-lg border border-brand-dark/10 transition-transform hover:scale-110 hover:text-brand-red focus:outline-none" aria-label="Chiudi finestra">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
      <img src="/images/satispay_qr.jpg" alt="QR code Satispay Ingrandito" class="w-full max-w-md h-auto rounded-xl shadow-inner" />
    </div>
  </div>

</BaseLayout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReducedMotion) {
    // Hero Entrance
    gsap.fromTo(".js-contatti-reveal", 
      { y: 30, opacity: 0 },
      { y: 0, opacity: 1, duration: 1, stagger: 0.15, ease: "power3.out", delay: 0.1 }
    );

    // Cards Reveal
    gsap.fromTo(".js-contatti-card",
      { y: 40, opacity: 0 },
      {
        scrollTrigger: {
          trigger: ".bg-brand-cream",
          start: "top 80%",
          once: true,
        },
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.15,
        ease: "power3.out",
      }
    );

  } else {
    document.querySelectorAll(".js-contatti-reveal, .js-contatti-card").forEach(el => {
      el.classList.remove("opacity-0");
    });
  }

  // QR Modal Logic
  const qrTriggers = document.querySelectorAll('.js-qr-trigger');
  const modal = document.getElementById('qr-modal');
  const modalContent = document.getElementById('qr-modal-content');
  const closeBtn = document.getElementById('close-qr-modal');

  function openModal() {
    if(!modal || !modalContent) return;
    modal.classList.remove('invisible');
    modal.classList.remove('opacity-0');
    modal.classList.add('opacity-100');
    modalContent.classList.remove('scale-95');
    modalContent.classList.add('scale-100');
    document.body.style.overflow = 'hidden'; // Prevent scrolling
  }

  function closeModal() {
    if(!modal || !modalContent) return;
    modal.classList.remove('opacity-100');
    modal.classList.add('opacity-0');
    modalContent.classList.remove('scale-100');
    modalContent.classList.add('scale-95');
    
    // Wait for transition to finish before hiding completely
    setTimeout(() => {
      modal.classList.add('invisible');
      document.body.style.overflow = ''; // Restore scrolling
    }, 300);
  }

  qrTriggers.forEach(trigger => {
    trigger.addEventListener('click', openModal);
  });

  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  if (modal) {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
  }
  
  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal && !modal.classList.contains('invisible')) {
      closeModal();
    }
  });

</script>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
